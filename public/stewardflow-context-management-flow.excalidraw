      "index": "c059",
      "frameId": null,
      "text": "prune 不删 Observation.content\n只打 compacted_at 标记\n真正变成占位符发生在下次 build_messages()",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "prune 不删 Observation.content\n只打 compacted_at 标记\n真正变成占位符发生在下次 build_messages()",
      "lineHeight": 1.25,
      "baseline": 14,
      "autoResize": false
    },
